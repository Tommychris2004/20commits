# Copy this file to .env and fill in values
# NEVER commit .env to git

# ---- Database ----
DB_PASSWORD=gridnode_dev_secret_change_me
DATABASE_URL=postgresql://gridnode:gridnode_dev_secret_change_me@localhost:5432/gridnode

# ---- JWT (generate with: openssl rand -base64 48) ----
JWT_SECRET=change_me_generate_with_openssl_rand_base64_48_minimum_32_chars
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret_also_32_chars_minimum

# ---- App ----
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# ---- Carbon market ----
CARBON_MARKET_PRICE_USD=7.50
NGN_USD_RATE=1580
GRIDNODE_CARBON_FEE_PCT=0.30

# ---- Energy tariffs (NGN/kWh) ----
TARIFF_GENERATOR_NGN_KWH=450
TARIFF_SOLAR_NGN_KWH=0
TARIFF_GRID_NGN_KWH=68

# ---- CO2 factor ----
CO2_FACTOR_KG_PER_KWH=0.75

# ---- Simulator ----
API_BASE=http://localhost:3000
API_TOKEN=          # Set to JWT access_token after login
DEVICE_ID=          # Set to device UUID after registering
INTERVAL_MS=5000
